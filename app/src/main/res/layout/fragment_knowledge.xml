<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="18dp"
        android:paddingBottom="22dp">

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardBackgroundColor="#F7FAFF"
            app:cardCornerRadius="20dp"
            app:strokeColor="#CFE0FF"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="18dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="课程知识库"
                    android:textColor="#15203B"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="知识库支持增删改查，库内文件也支持增删改查和应用内查看。"
                    android:textColor="#4E5B80"
                    android:textSize="14sp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_kb_create"
                    style="@style/Widget.Material3.Button"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text="新建知识库" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="#F7FBFF"
            app:cardCornerRadius="20dp"
            app:strokeColor="#D8E3FF"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="18dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="知识库列表"
                    android:textColor="#15203B"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/card_kb_linear_algebra"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:clickable="true"
                    android:focusable="true"
                    app:cardBackgroundColor="#FCFDFF"
                    app:cardCornerRadius="14dp"
                    app:strokeColor="#E0E9FF"
                    app:strokeWidth="1dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="14dp">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="线性代数课程库"
                            android:textColor="#1A2E57"
                            android:textSize="15sp"
                            android:textStyle="bold" />

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="6dp"
                            android:layout_gravity="end"
                            android:orientation="horizontal">

                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/btn_kb_view_linear"
                                style="@style/Widget.NoteBook.Button.TextCompact"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="查看" />

                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/btn_kb_edit_linear"
                                style="@style/Widget.NoteBook.Button.TextCompact"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="4dp"
                                android:text="编辑" />

                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/btn_kb_delete_linear"
                                style="@style/Widget.NoteBook.Button.TextCompact"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="4dp"
                                android:text="删除"
                                android:textColor="#B42318" />
                        </LinearLayout>

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:text="文件 12 个 · 最近更新 2026-03-03"
                            android:textColor="#5C698B"
                            android:textSize="13sp" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/card_kb_probability"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:clickable="true"
                    android:focusable="true"
                    app:cardBackgroundColor="#FCFDFF"
                    app:cardCornerRadius="14dp"
                    app:strokeColor="#E0E9FF"
                    app:strokeWidth="1dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="14dp">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="概率统计课程库"
                            android:textColor="#1A2E57"
                            android:textSize="15sp"
                            android:textStyle="bold" />

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="6dp"
                            android:layout_gravity="end"
                            android:orientation="horizontal">

                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/btn_kb_view_probability"
                                style="@style/Widget.NoteBook.Button.TextCompact"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="查看" />

                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/btn_kb_edit_probability"
                                style="@style/Widget.NoteBook.Button.TextCompact"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="4dp"
                                android:text="编辑" />

                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/btn_kb_delete_probability"
                                style="@style/Widget.NoteBook.Button.TextCompact"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="4dp"
                                android:text="删除"
                                android:textColor="#B42318" />
                        </LinearLayout>

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:text="文件 9 个 · 最近更新 2026-03-02"
                            android:textColor="#5C698B"
                            android:textSize="13sp" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/card_kb_machine_learning"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:clickable="true"
                    android:focusable="true"
                    app:cardBackgroundColor="#FCFDFF"
                    app:cardCornerRadius="14dp"
                    app:strokeColor="#E0E9FF"
                    app:strokeWidth="1dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="14dp">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="机器学习导论课程库"
                            android:textColor="#1A2E57"
                            android:textSize="15sp"
                            android:textStyle="bold" />

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="6dp"
                            android:layout_gravity="end"
                            android:orientation="horizontal">

                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/btn_kb_view_ml"
                                style="@style/Widget.NoteBook.Button.TextCompact"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="查看" />

                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/btn_kb_edit_ml"
                                style="@style/Widget.NoteBook.Button.TextCompact"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="4dp"
                                android:text="编辑" />

                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/btn_kb_delete_ml"
                                style="@style/Widget.NoteBook.Button.TextCompact"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="4dp"
                                android:text="删除"
                                android:textColor="#B42318" />
                        </LinearLayout>

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:text="文件 15 个 · 最近更新 2026-03-01"
                            android:textColor="#5C698B"
                            android:textSize="13sp" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>
    </LinearLayout>
</ScrollView>
